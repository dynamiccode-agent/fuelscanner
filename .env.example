# Upstash Redis — create free instance at upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Protects the /api/sync endpoint from public triggers
# Vercel injects this automatically for cron calls; set same value in Vercel env vars
CRON_SECRET=your_secret_here

# Default scrape location (Preston VIC — override as needed)
DEFAULT_LAT=-37.74083588803176
DEFAULT_LNG=145.00965855160715
DEFAULT_RADIUS=5
